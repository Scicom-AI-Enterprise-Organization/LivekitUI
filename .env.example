# ===========================================
# LiveKit Server
# ===========================================
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# ===========================================
# Database Configuration
# ===========================================
# Supported: "sqlite" | "postgres"
# Default: sqlite
DB_TYPE=sqlite

# --- SQLite (default) ---
# Path to the SQLite database file (relative to project root)
SQLITE_PATH=./data/livekit.db

# --- PostgreSQL ---
# Uncomment and fill in to use PostgreSQL instead of SQLite
# DB_TYPE=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=livekit
# POSTGRES_PASSWORD=your_password_here
# POSTGRES_DB=livekit
# Or use a connection string instead:
# DATABASE_URL=postgresql://livekit:your_password_here@localhost:5432/livekit

# ===========================================
# Session
# ===========================================
# Secret used to generate session tokens (change in production)
SESSION_SECRET=change-me-to-a-random-secret

# ===========================================
# Sandbox
# ===========================================
# Base URL for sandbox apps. Sandboxes are proxied at {domain}/sandbox/{name}
# Default: http://localhost:3000
NEXT_PUBLIC_SANDBOX_DOMAIN=http://localhost:3000

# ===========================================
# Webhooks (optional)
# ===========================================
# URL that LiveKit server sends events to (room started, participant joined, etc.)
# LIVEKIT_WEBHOOK_URL=https://your-domain.com/api/webhooks/livekit

# ===========================================
# Telephony Providers (optional)
# ===========================================
# Configure one or more providers to import phone numbers.
# Numbers can always be added manually without any provider.

# --- Twilio ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here

# --- Vonage (Nexmo) ---
# VONAGE_API_KEY=your_api_key
# VONAGE_API_SECRET=your_api_secret

# --- Telnyx ---
# TELNYX_API_KEY=KEY_your_api_key_here
